<Window x:Class="VideoJam.UI.VlcDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Background="Black"
        Title="VideoJam Display">
    <Grid>
        <!-- Fallback PNG image (shown when no video is assigned to this display) -->
        <Image x:Name="FallbackImage" Stretch="Uniform" />
        <!-- VLC render surface host — implementation in Phase 2 -->
    </Grid>
</Window>
