<Window x:Class="VideoJam.UI.VlcDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Background="Black"
        Title="VideoJam Display">
    <Grid Background="Black">
        <!-- VLC render surface host — LibVLC renders directly into this element's HWND.
             Must sit below the fallback image so ShowVideo()/ShowFallback() can toggle. -->
        <Border x:Name="VlcHost" Background="Black" />

        <!-- Fallback PNG image (shown when no video is assigned to this display,
             or between songs). Sits above VlcHost in Z-order. -->
        <Image x:Name="FallbackImage" Stretch="Uniform" />
    </Grid>
</Window>
